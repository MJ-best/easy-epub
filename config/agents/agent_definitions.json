{
  "version": "1.0.0",
  "platform": "flutter-web-supabase-multi-agent-mvp",
  "product_type": "workflow_artifact_generation",
  "principles": [
    "Workflow-first, not chat-first",
    "Each agent owns exactly one layer of the stack",
    "Every output must be structured and machine-readable",
    "The orchestrator coordinates, but does not author domain artifacts"
  ],
  "artifact_types": [
    "execution_plan",
    "prd",
    "schema",
    "ui_spec",
    "code_plan",
    "qa_report",
    "execution_log"
  ],
  "agents": [
    {
      "id": "orchestrator",
      "name": "Orchestrator Agent",
      "role": "Plan and coordinate the multi-agent workflow.",
      "scope": [
        "Break project_goal into ordered tasks",
        "Assign tasks to specialist agents",
        "Track dependencies, status, and handoffs",
        "Detect missing or conflicting outputs"
      ],
      "boundaries": [
        "Does not write PRD content in detail",
        "Does not design database schema",
        "Does not generate Flutter UI/code",
        "Does not perform QA beyond coordination"
      ],
      "inputs": [
        "project_goal",
        "workspace_context",
        "existing_artifacts"
      ],
      "outputs": [
        "execution_plan",
        "task_graph",
        "handoff_rules"
      ],
      "structured_output_contract": {
        "type": "object",
        "required": [
          "project_goal",
          "plan_id",
          "stages",
          "task_graph",
          "next_agent",
          "risks"
        ],
        "properties": {
          "project_goal": { "type": "string" },
          "plan_id": { "type": "string" },
          "stages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "owner", "depends_on", "deliverables"],
              "properties": {
                "id": { "type": "string" },
                "owner": { "type": "string" },
                "depends_on": { "type": "array", "items": { "type": "string" } },
                "deliverables": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "task_graph": { "type": "array", "items": { "type": "string" } },
          "next_agent": { "type": "string" },
          "risks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "id": "pm",
      "name": "PM Agent",
      "role": "Turn the goal into product requirements.",
      "scope": [
        "Generate PRD",
        "Define user flows",
        "List MVP features and non-goals",
        "Specify acceptance criteria"
      ],
      "boundaries": [
        "Does not define database schema",
        "Does not write Flutter UI/code",
        "Does not run QA checks"
      ],
      "inputs": [
        "project_goal",
        "execution_constraints",
        "target_platform"
      ],
      "outputs": [
        "prd",
        "feature_list",
        "user_flow",
        "acceptance_criteria"
      ],
      "structured_output_contract": {
        "type": "object",
        "required": [
          "product_summary",
          "mvp_scope",
          "features",
          "user_flow",
          "acceptance_criteria",
          "non_goals"
        ],
        "properties": {
          "product_summary": { "type": "string" },
          "mvp_scope": { "type": "array", "items": { "type": "string" } },
          "features": { "type": "array", "items": { "type": "string" } },
          "user_flow": { "type": "array", "items": { "type": "string" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "non_goals": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "id": "system_designer",
      "name": "System Designer Agent",
      "role": "Design the data model and Supabase integration contract.",
      "scope": [
        "Design Postgres schema",
        "Define RLS rules and ownership model",
        "Map entities and relations",
        "Specify storage and execution log strategy"
      ],
      "boundaries": [
        "Does not define product scope",
        "Does not generate UI",
        "Does not write Flutter app code"
      ],
      "inputs": [
        "prd",
        "workflow_requirements",
        "security_requirements"
      ],
      "outputs": [
        "schema",
        "rls_policy_spec",
        "entity_relationship_map"
      ],
      "structured_output_contract": {
        "type": "object",
        "required": [
          "entities",
          "relationships",
          "rls_model",
          "indexes",
          "migration_notes"
        ],
        "properties": {
          "entities": { "type": "array", "items": { "type": "string" } },
          "relationships": { "type": "array", "items": { "type": "string" } },
          "rls_model": { "type": "array", "items": { "type": "string" } },
          "indexes": { "type": "array", "items": { "type": "string" } },
          "migration_notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "id": "flutter",
      "name": "Flutter Agent",
      "role": "Generate the web-first UI structure and implementation plan.",
      "scope": [
        "Design Flutter feature structure",
        "Define screens, routing, and state ownership",
        "Generate UI skeleton code",
        "Map workflow artifacts to views"
      ],
      "boundaries": [
        "Does not define product strategy",
        "Does not change database schema",
        "Does not write QA reports"
      ],
      "inputs": [
        "prd",
        "schema",
        "ui_requirements",
        "platform_constraints"
      ],
      "outputs": [
        "ui_spec",
        "code_plan",
        "flutter_skeleton"
      ],
      "structured_output_contract": {
        "type": "object",
        "required": [
          "app_structure",
          "screens",
          "routing",
          "state_management",
          "implementation_notes"
        ],
        "properties": {
          "app_structure": { "type": "array", "items": { "type": "string" } },
          "screens": { "type": "array", "items": { "type": "string" } },
          "routing": { "type": "array", "items": { "type": "string" } },
          "state_management": { "type": "array", "items": { "type": "string" } },
          "implementation_notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "id": "qa",
      "name": "QA Agent",
      "role": "Validate outputs and identify missing or risky cases.",
      "scope": [
        "Check completeness and consistency",
        "Identify edge cases",
        "Find security and workflow gaps",
        "Report test coverage gaps"
      ],
      "boundaries": [
        "Does not change requirements",
        "Does not redesign schema or UI",
        "Does not author production code"
      ],
      "inputs": [
        "execution_plan",
        "prd",
        "schema",
        "ui_spec",
        "code_plan"
      ],
      "outputs": [
        "qa_report",
        "risk_register",
        "open_issues"
      ],
      "structured_output_contract": {
        "type": "object",
        "required": [
          "summary",
          "pass_fail",
          "issues",
          "missing_cases",
          "recommendations"
        ],
        "properties": {
          "summary": { "type": "string" },
          "pass_fail": { "type": "string" },
          "issues": { "type": "array", "items": { "type": "string" } },
          "missing_cases": { "type": "array", "items": { "type": "string" } },
          "recommendations": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  ],
  "workflow": {
    "stages": [
      {
        "id": "intake",
        "owner": "orchestrator",
        "deliverable": "execution_plan"
      },
      {
        "id": "product_definition",
        "owner": "pm",
        "deliverable": "prd"
      },
      {
        "id": "system_design",
        "owner": "system_designer",
        "deliverable": "schema"
      },
      {
        "id": "ui_and_code",
        "owner": "flutter",
        "deliverable": "ui_spec"
      },
      {
        "id": "validation",
        "owner": "qa",
        "deliverable": "qa_report"
      }
    ],
    "handoff_rules": [
      "Each stage must include upstream artifact references",
      "Duplicate work is blocked by explicit ownership boundaries",
      "QA may request a single replay of a failed stage",
      "Artifacts must be stored with project_id and workspace_id"
    ]
  }
}
